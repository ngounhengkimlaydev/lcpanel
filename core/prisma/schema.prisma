generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Module {
  id          Int          @id @default(autoincrement())
  module_name String
  module_key  String
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  permissions Permission[]
  roleModules RoleModule[]

  @@map("module")
}

model Permission {
  id              Int          @id @default(autoincrement())
  permission_name String
  module_id       Int
  created_at      DateTime     @default(now())
  module          Module       @relation(fields: [module_id], references: [id], onDelete: Cascade)
  roleModules     RoleModule[]

  @@index([module_id], map: "idx_permission_module_id")
  @@map("permission")
}

model UserType {
  id         Int        @id @default(autoincrement())
  type       String
  level      Int
  created_at DateTime   @default(now())
  roles      Role[]
  users      User[]
  customers  Customer[]

  @@map("user_type")
}

model IPAdress {
  id         Int      @id @default(autoincrement())
  name       String?
  ip_address String
  status     Int      @default(1)
  created_at DateTime @default(now())

  @@map("ip_address")
}

model Role {
  id           Int          @id @default(autoincrement())
  role_name    String
  role_desc    String?
  user_type_id Int
  created_at   DateTime     @default(now())
  created_by   Int?
  user_type    UserType     @relation(fields: [user_type_id], references: [id])
  roleModules  RoleModule[]
  Users        User[]
  customers    Customer[]

  @@index([user_type_id], map: "idx_role_user_type_id_fkey")
  @@map("role")
}

model User {
  id           Int       @id @default(autoincrement())
  full_name    String
  username     String    @unique @db.VarChar(100)
  password     String
  image        String?
  email        String?
  phone        String?
  role_id      Int
  user_type_id Int
  auth_token   String?
  last_login   DateTime?
  status       Int       @default(1)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  role         Role      @relation(fields: [role_id], references: [id])
  user_type    UserType  @relation(fields: [user_type_id], references: [id])

  @@index([role_id], map: "idx_users_role_id")
  @@index([user_type_id], map: "idx_users_user_type_id")
  @@map("users")
}

model Customer {
  id                  BigInt              @id @default(autoincrement())
  user_type_id        Int                 @default(6)
  role_id             Int                 @default(2)
  code                String?
  image               String?
  name                String
  phone               String
  email               String?
  gender              Int?
  password            String?
  google              String?
  apple_id            String?
  firebase_uid        String?
  status              Int                 @default(1) //1 Active, 2 Suspended
  deleted_at          DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  user_type           UserType            @relation(fields: [user_type_id], references: [id])
  role                Role                @relation(fields: [role_id], references: [id])
  gitConnections      GitConnection[]
  gitProjects         GitProject[]
  deploymentHistories DeploymentHistory[]
  invoices            Invoices[]
  subscription        Subscriptions?

  @@unique([phone, email])
  @@index([user_type_id, role_id])
  @@map("customer")
}

model RoleModule {
  id            Int        @id @default(autoincrement())
  role_id       Int
  module_id     Int
  permission_id Int
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  module        Module     @relation(fields: [module_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role       @relation(fields: [role_id], references: [id])

  @@index([module_id], map: "idx_role_module_module_id_fkey")
  @@index([permission_id], map: "idx_role_module_permission_id_fkey")
  @@index([role_id], map: "idx_role_module_role_id_fkey")
  @@map("role_module")
}

model UserLog {
  id           Int      @id @default(autoincrement())
  log_name     String?
  description  String   @db.Text
  subject_type String?
  event        String?
  subject_id   Int?
  causer_type  String?
  causer_id    Int?
  properties   Json?
  batch_uuid   String?  @db.Char(36)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([subject_type, subject_id], map: "subject")
  @@index([causer_type, causer_id], map: "causer")
  @@index([log_name], map: "activity_log_log_name_index")
  @@map("user_log")
}

model GitConnection {
  id               BigInt    @id @default(autoincrement())
  customer_id      BigInt
  provider         String
  provider_user_id String
  username         String?
  avatar_url       String?
  access_token     String
  refresh_token    String?
  scope            String?
  expires_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  projects   GitProject[]
  customer   Customer     @relation(fields: [customer_id], references: [id])
  customerId Int?

  @@unique([customer_id, provider])
  @@index([customer_id])
  @@map("git_connection")
}

model GitProject {
  id               Int       @id @default(autoincrement())
  customer_id      BigInt
  connection_id    BigInt?
  provider         String
  provider_repo_id String
  name             String
  full_name        String
  clone_url        String
  ssh_url          String?
  html_url         String?
  default_branch   String?
  local_path       String?
  status           String    @default("imported")
  last_pulled_at   DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  connection          GitConnection?      @relation(fields: [connection_id], references: [id])
  customer            Customer            @relation(fields: [customer_id], references: [id])
  deploymentHistories DeploymentHistory[]

  @@unique([customer_id, provider, provider_repo_id])
  @@index([customer_id, connection_id])
  @@map("git_project")
}

model DeploymentHistory {
  id             Int      @id @default(autoincrement())
  customer_id    BigInt
  project_id     Int
  project_name   String
  branch         String
  commit_hash    String?
  commit_short   String?
  commit_message String?
  author         String?
  status         String
  trigger        String
  message        String
  environment    String   @default("Production")
  domain         String?
  install_time   String?
  build_time     String?
  deploy_time    String?
  duration_ms    Int?
  plan_name      String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  customer Customer   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  project  GitProject @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([customer_id, created_at], map: "idx_deployment_history_customer_created_at")
  @@index([project_id, created_at], map: "idx_deployment_history_project_created_at")
  @@map("deployment_history")
}

model Plans {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(50)
  description    String
  price          Decimal         @db.Decimal(10, 2)
  cpu            Float?          @db.DoublePrecision
  ram            Int?
  disk_space     Int
  domain         Int
  email          Int?
  ssl            Boolean         @default(true)
  database       Int
  website        Int             @default(1)
  ftp_account    Int?            @default(1)
  cronjob        Int?            @default(0)
  backup         Boolean?        @default(false)
  cdn            Boolean?        @default(false)
  staging        Boolean?        @default(false)
  ssh_access     Boolean?        @default(false)
  docker_support Boolean?        @default(false)
  bandwidth      Float           @db.DoublePrecision
  type           Int             @db.SmallInt //1 Web Hosting, 2 VPS Hosting, 3 DB Hosting, 4 Cloud Hosting
  status         Int             @default(1) //1 Active, 2 Disable
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  subscriptions  Subscriptions[]

  @@map("plans")
}

model Subscriptions {
  id          BigInt     @id @default(autoincrement())
  customer_id BigInt     @unique
  customer    Customer   @relation(fields: [customer_id], references: [id])
  plan_id     Int
  plan        Plans      @relation(fields: [plan_id], references: [id])
  start_date  DateTime
  end_date    DateTime
  status      Int        @default(1) //1 Active, 2 Disable
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  invoices    Invoices[]

  @@index([customer_id, plan_id])
  @@map("subscriptions")
}

model Invoices {
  id              BigInt        @id @default(autoincrement())
  code            String        @unique @db.VarChar(50)
  customer_id     BigInt
  customers       Customer      @relation(fields: [customer_id], references: [id])
  subscription_id BigInt
  subscription    Subscriptions @relation(fields: [subscription_id], references: [id])
  status          Int           @default(1) //1 Paid, 2 Unpaid, 3 Overdue
  due_date        DateTime
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@index([customer_id])
  @@map("invoices")
}
