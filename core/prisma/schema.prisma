generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Module {
  id          Int          @id @default(autoincrement())
  module_name String
  module_key  String
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  permissions Permission[]
  roleModules RoleModule[]

  @@map("module")
}

model Permission {
  id              Int          @id @default(autoincrement())
  permission_name String
  module_id       Int
  created_at      DateTime     @default(now())
  module          Module       @relation(fields: [module_id], references: [id], onDelete: Cascade)
  roleModules     RoleModule[]

  @@index([module_id], map: "idx_permission_module_id")
  @@map("permission")
}

model UserType {
  id         Int      @id @default(autoincrement())
  type       String
  level      Int
  created_at DateTime @default(now())
  roles      Role[]
  users      User[]

  @@map("user_type")
}

model IPAdress {
  id         Int      @id @default(autoincrement())
  name       String?
  ip_address String
  status     Int      @default(1)
  created_at DateTime @default(now())

  @@map("ip_address")
}

model Role {
  id           Int          @id @default(autoincrement())
  role_name    String
  role_desc    String?
  user_type_id Int
  created_at   DateTime     @default(now())
  created_by   Int?
  user_type    UserType     @relation(fields: [user_type_id], references: [id])
  roleModules  RoleModule[]
  Users        User[]

  @@index([user_type_id], map: "idx_role_user_type_id_fkey")
  @@map("role")
}

model User {
  id           Int       @id @default(autoincrement())
  full_name    String
  username     String    @unique @db.VarChar(100)
  password     String
  image        String?
  email        String?
  phone        String?
  role_id      Int
  user_type_id Int
  auth_token   String?
  last_login   DateTime?
  status       Int       @default(1)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  role         Role      @relation(fields: [role_id], references: [id])
  user_type    UserType  @relation(fields: [user_type_id], references: [id])

  @@index([role_id], map: "idx_users_role_id")
  @@index([user_type_id], map: "idx_users_user_type_id")
  @@map("users")
}

model Customer {
  id              Int              @id @default(autoincrement())
  code            String?
  image           String?
  name            String
  phone           String
  email           String?
  gender          Int?
  password        String?
  google          String?
  apple_id        String?
  firebase_uid    String?
  status          Int             @default(1)
  deleted_at      DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  gitConnections  GitConnection[]
  gitProjects     GitProject[]

  @@map("customer")
}

model RoleModule {
  id            Int        @id @default(autoincrement())
  role_id       Int
  module_id     Int
  permission_id Int
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  module        Module     @relation(fields: [module_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])
  role          Role       @relation(fields: [role_id], references: [id])

  @@index([module_id], map: "idx_role_module_module_id_fkey")
  @@index([permission_id], map: "idx_role_module_permission_id_fkey")
  @@index([role_id], map: "idx_role_module_role_id_fkey")
  @@map("role_module")
}

model UserLog {
  id           Int      @id @default(autoincrement())
  log_name     String?
  description  String   @db.Text
  subject_type String?
  event        String?
  subject_id   Int?
  causer_type  String?
  causer_id    Int?
  properties   Json?
  batch_uuid   String?  @db.Char(36)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([subject_type, subject_id], map: "subject")
  @@index([causer_type, causer_id], map: "causer")
  @@index([log_name], map: "activity_log_log_name_index")
  @@map("user_log")
}

model GitConnection {
  id               Int       @id @default(autoincrement())
  customer_id      Int
  provider         String
  provider_user_id String
  username         String?
  avatar_url       String?
  access_token     String
  refresh_token    String?
  scope            String?
  expires_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  projects   GitProject[]
  customer   Customer     @relation(fields: [customer_id], references: [id])
  customerId Int?

  @@unique([customer_id, provider])
  @@index([customer_id])
  @@map("git_connection")
}

model GitProject {
  id               Int       @id @default(autoincrement())
  customer_id      Int
  connection_id    Int?
  provider         String
  provider_repo_id String
  name             String
  full_name        String
  clone_url        String
  ssh_url          String?
  html_url         String?
  default_branch   String?
  local_path       String?
  status           String    @default("imported")
  last_pulled_at   DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  connection GitConnection? @relation(fields: [connection_id], references: [id])
  customer   Customer       @relation(fields: [customer_id], references: [id])

  @@unique([customer_id, provider, provider_repo_id])
  @@index([customer_id, connection_id])
  @@map("git_project")
}
